# Shared PostgreSQL
POSTGRES_DB=acemcp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Frontend / Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-random-secret
AUTH_LINUXDO_ID=your-linuxdo-client-id
AUTH_LINUXDO_SECRET=your-linuxdo-client-secret
NEXT_PUBLIC_RELAY_URL=http://localhost:3009/

# Relay upstream
AUGMENT_API_URL=https://your-augment-upstream.example.com
AUGMENT_API_TOKEN=your-augment-api-token

# Relay cache/session tuning
API_KEY_CACHE_TTL=1h
SESSION_TTL=5m
