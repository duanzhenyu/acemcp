# Shared PostgreSQL
POSTGRES_DB=acemcp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Frontend web session
WEB_SESSION_SECRET=replace-with-a-random-session-secret
WEB_SESSION_TTL=12h
NEXT_PUBLIC_RELAY_URL=http://localhost:3009/

# Admin bootstrap
ADMIN_USER_IDS=admin
BOOTSTRAP_ADMIN_USER_ID=admin
BOOTSTRAP_ADMIN_NAME=ACE Admin
BOOTSTRAP_ADMIN_NOTE=Bootstrap administrator
BOOTSTRAP_ADMIN_API_KEY=ace_replace_with_bootstrap_admin_key

# Relay upstream
AUGMENT_API_URL=https://your-augment-upstream.example.com
AUGMENT_API_TOKEN=your-augment-api-token

# Relay cache/session tuning
API_KEY_CACHE_TTL=1h
SESSION_TTL=5m
